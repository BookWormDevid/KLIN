[MASTER]
ignore = migrations, .venv, venv, .env, x3d_net.py
max-module-lines = 1200
jobs = 1

[MESSAGES CONTROL]
disable =
    broad-exception-caught,


[FORMAT]
max-line-length = 120
docstring-min-length = 5

[VARIABLES]
dummy-variables-rgx = _|dummy|ignore

[BASIC]
# По умолчанию: [a-z_][a-z0-9_]{2,30}$
# variable-rgx = [a-z_][a-z0-9_]{0,30}$
# function-rgx = [a-z_][a-z0-9_]{2,50}$
# class-rgx = [A-Z_][a-zA-Z0-9]+$
# const-rgx = (([A-Z_][A-Z0-9_]*)|(__.*__))$
# argument-rgx = [a-z_][a-z0-9_]{0,30}$

[IMPORTS]
known-standard-library = sys, os, re, typing, collections, datetime
known-third-party = pytest, sqlalchemy

[TYPECHECK]
ignored-classes = SQLAlchemy, scoped_session
ignored-modules = dotenv
extension-pkg-allow-list = cv2

generated-members =
    cv2.*,
    request,
    response,
    status_code,
    json,
    text

[MISCELLANEOUS]
notes = FIXME, XXX, TODO

[LOGGING]
logging-format-style = old
