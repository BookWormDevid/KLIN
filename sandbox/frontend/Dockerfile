# 1. Используем образ Node.js
FROM node:18-alpine

# 2. Устанавливаем рабочую директорию
WORKDIR /app

# 3. Копируем файлы зависимостей
# Это важно: сначала копируем только их, чтобы Docker закешировал установку библиотек
COPY package*.json ./

# 4. Устанавливаем библиотеки ВНУТРИ контейнера
RUN npm install

# 5. Копируем весь остальной код фронта
COPY . .

# 6. Открываем порт (обычно 3000 для React/Vite)
EXPOSE 3000

# 7. Запускаем проект
CMD ["npm", "start"]