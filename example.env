DEBUG=1
COMPOSE_PROFILES=ops,observability

# Public hosts for Traefik-routed services. Replace *.localhost with your real domains on the server if you have one
KLIN_API_HOST=api.localhost
AIRFLOW_HOST=airflow.localhost
PGADMIN_HOST=pgadmin.localhost
GRAFANA_HOST=grafana.localhost
PROMETHEUS_HOST=prometheus.localhost
ALERTMANAGER_HOST=alertmanager.localhost
TRAEFIK_HOST=traefik.localhost

# Bind addresses and published ports. For remote access, switch 127.0.0.1 -> 0.0.0.0.
TRAEFIK_BIND_HOST=127.0.0.1
TRAEFIK_HTTP_PORT=80

POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PORT=5432

RABBITMQ_BIND_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

TRITON_BIND_HOST=127.0.0.1
TRITON_HTTP_PORT=8000
TRITON_GRPC_PORT=8001
TRITON_METRICS_PORT=8002

POSTGRES_USER=klin_user_change_me
POSTGRES_PASSWORD=klin_password_change_me

APP_DB_NAME=klin
APP_DB_USER=klin_app_change_me
APP_DB_PASSWORD=klin_app_password_change_me

AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_USER=airflow_change_me
AIRFLOW_DB_PASSWORD=airflow_password_change_me

RABBITMQ_USER=rabbit_user_change_me
RABBITMQ_PASSWORD=rabbit_password_change_me
RABBITMQ_INTERNAL_PORT=5672

S3_ENDPOINT_URL=https://your-s3-endpoint.example.com
S3_BUCKET_NAME=klin-videos
S3_ACCESS_KEY_ID=s3_access_change_me
S3_SECRET_ACCESS_KEY=s3_secret_change_me
S3_REGION=us-east-1
S3_ADDRESSING_STYLE=path
S3_KEY_PREFIX=klin/uploads

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=pgadmin_password_change_me
GRAFANA_ADMIN_PASSWORD=grafana_password_change_me

ALERT_EMAIL_TO=alerts@example.com
ALERT_EMAIL_FROM=noreply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp_user_change_me
SMTP_PASSWORD=smtp_password_change_me
TELEGRAM_BOT_TOKEN=000000000:telegram_bot_token_change_me
TELEGRAM_CHAT_ID=123456789

MLFLOW_TRACKING_URI=sqlite:///./mlflow/mlflow.db
ML_METRICS_DB_NAME=ml
ML_METRICS_DB_USER=klin_user_change_me
ML_METRICS_DB_PASSWORD=klin_password_change_me
ML_METRICS_DB_HOST=localhost
ML_METRICS_DB_PORT=5432

AIRFLOW_UID=50000
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_SECRET_KEY=change_me_long_random_string
AIRFLOW_FERNET_KEY=change_me_32_byte_fernet_key

# Host-side DSN for local commands like make migration / make start-api-local.
DATABASE_URL=postgresql+asyncpg://klin_app_change_me:klin_app_password_change_me@localhost:5432/klin

# Keep "postgresql" only when Airflow runs in this same Docker network; otherwise use the public DB host.
AIRFLOW_DATABASE_URL=postgresql+psycopg2://airflow_change_me:airflow_password_change_me@postgresql:5432/airflow

# Host-side broker URL for local commands like make start-queue-local.
RABBIT_URL=amqp://rabbit_user_change_me:rabbit_password_change_me@localhost:5672/

# Настройки ниже - опциональные и имеют дефолтные значения, идентичные предоставленным в app/config
KLIN_AIRFLOW_IMAGE=klin-airflow:3.1.7-fab3.3.0
KLIN_BATCH_RUNNER_IMAGE=klin-batch-runner:latest
VIDEOMAE_PATH="models/videomae-UCF-crime"
MAX_RETRY_ATTEMPTS=1
TRITON_GRPC_URL="127.0.0.1:8001"
